{
  "expo": {
    "name": "oxyl",
    "slug": "oxyl-frontend",
    "version": "1.0.0",
    "scheme": "oxyl",
    "platforms": [
      "ios"
    ],
    "userInterfaceStyle": "dark",
    "backgroundColor": "#000000",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-system-ui"
    ],
    "experiments": {
      "typedRoutes": true,
      "tsconfigPaths": true
    },
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/logo-notext.png",
      "resizeMode": "contain",
      "backgroundColor": "#000000",
      "duration": 0
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "icon": "./assets/icon.png",
      "bundleIdentifier": "com.anonymous.oxyl-frontend"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo-notext.svg"
      }
    }
  }
}
